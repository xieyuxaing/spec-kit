root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 4

[*.{ps1,psm1,psd1}]
indent_size = 4

[Makefile]
indent_style = tab
